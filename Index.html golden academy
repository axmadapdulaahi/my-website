    <!-- Video Player Modal Layer -->
    <div class="video-modal" id="videoModal">
        <div class="modal-content">
            <button class="close-btn" onclick="closeVideo()"><i class="fas fa-times"></i></button>
            <div class="video-wrapper">
                <iframe id="videoPlayer" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
        </div>
    </div>

    <script>
        const modal = document.getElementById('videoModal');
        const player = document.getElementById('videoPlayer');

        function openVideo(videoUrl) {
            player.src = videoUrl;
            modal.classList.add('active');
        }

        function closeVideo() {
            modal.classList.remove('active');
            player.src = "";
        }

        window.onclick = function(event) {
            if (event.target == modal) {
                closeVideo();
            }
        }
    </script>

